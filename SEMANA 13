-- CURSOR
DECLARE @IdL INT;
DECLARE @NombreL VARCHAR(100);


DECLARE mi_cursor CURSOR FOR 
SELECT LibroID, Titulo FROM Libros;

OPEN mi_cursor;

FETCH NEXT FROM mi_cursor INTO @IdL, @NombreL;


WHILE @@FETCH_STATUS = 0
BEGIN

    IF dbo.fn_ContarPrestamosLibro(@IdL) > 0
        PRINT 'El libro: ' + @NombreL + ' ya ha sido prestado.';
    ELSE
        PRINT 'El libro: ' + @NombreL + ' está disponible (nunca prestado).';

    FETCH NEXT FROM mi_cursor INTO @IdL, @NombreL;
END;

CLOSE mi_cursor;
DEALLOCATE mi_cursor;
GO
