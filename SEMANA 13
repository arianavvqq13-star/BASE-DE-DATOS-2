CREATE FUNCTION fn_ContarPrestamosLibro (@IdLibro INT)
RETURNS INT
AS
BEGIN
    DECLARE @Total INT;
    SELECT @Total = COUNT(*) FROM Prestamos WHERE LibroID = @IdLibro;
    RETURN @Total;
END;
GO

-- ¿Cómo se usa? Un SELECT básico
SELECT Titulo, dbo.fn_ContarPrestamosLibro(LibroID) AS [Veces Prestado] 
FROM Libros;
GO


--  PROCEDIMIENTO ALMACENADO
CREATE PROCEDURE sp_InsertarPrestamo
    @IdLibro INT,
    @IdUsuario INT
AS
BEGIN
    -- Verificar con un IF si el libro realmente existe
    IF EXISTS (SELECT 1 FROM Libros WHERE LibroID = @IdLibro)
    BEGIN
        INSERT INTO Prestamos (LibroID, UsuarioID, FechaSalida)
        VALUES (@IdLibro, @IdUsuario, GETDATE());
        
        PRINT 'Préstamo registrado con éxito.';
    END
    ELSE
    BEGIN
        PRINT 'Error: El libro no existe en la base de datos.';
    END
END;
GO


