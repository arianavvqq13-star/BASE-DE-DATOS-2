--MOSTRAR TODAS LAS TABLAS
SELECT *FROM Usuarios;
SELECT*FROM Libros;
SELECT*FROM Prestamos;

SELECT Titulo,Categoria FROM Libros;

--INNER JOIN
SELECT 
U.Nombre,
L.Titulo,
P.FechaSalida 
FROM Prestamos AS P
INNER JOIN Usuarios U ON P.UsuarioID=U.UsuarioID
INNER JOIN Libros L ON P.LibroID=L.LibroID;

--WHERE Y ORDER BY
SELECT Titulo, Autor, Categoria
FROM Libros
WHERE Categoria='Sistemas';

SELECT Titulo,Autor
FROM Libros
ORDER BY Titulo ASC;

--LIKE (QEUE COMIENCEN CON E)
SELECT Titulo,Autor 
FROM Libros 
WHERE TituLO lIKE'E%';

--BETWEEN
SELECT Titulo, Categoria 
FROM Libros
WHERE LibroID BETWEEN 1 AND 3;

--IS NULL
Select Nombre,DNI
FROM Usuarios
WHERE Telefono IS NULL;

--FUNCIONES DE GRUPO
SELECT COUNT (*) AS[Total de Libros]
FROM Libros;

--CLAUSULA GROUP BY
SELECT Categoria, COUNT(*)AS [Cantidad de Libros]
FROM Libros
GROUP BY Categoria;

--HAVING
SELECT Categoria, COUNT(*) AS [Cantidad de Libros]
FROM Libros
GROUP BY Categoria
HAVING COUNT(*) = 1;

--USO DE CASE
SELECT Titulo, Categoria,
    CASE 
        WHEN Categoria = 'Sistemas' THEN 'Tecnología'
        ELSE 'General'
    END AS [Clasificación]
FROM Libros;

--SUBCONSULTAS
--EXISTS Y NOT EXITS
SELECT Nombre, Telefono
FROM Usuarios U
WHERE EXISTS (
    SELECT 1 
    FROM Prestamos P
    WHERE P.UsuarioID = U.UsuarioID
);

SELECT Titulo, Autor
FROM Libros L
WHERE NOT EXISTS (
    SELECT 1 
    FROM Prestamos P
    WHERE P.LibroID = L.LibroID
);
--IN
SELECT Titulo, Categoria
FROM Libros
WHERE LibroID IN (
    SELECT LibroID 
    FROM Prestamos
);

--LEFT JOIN
SELECT 
    U.Nombre AS NombreUsuario, 
    L.Titulo AS TituloLibro, 
    P.FechaSalida AS FechaPrestamo
FROM Usuarios U
LEFT JOIN Prestamos P ON U.UsuarioID = P.UsuarioID
LEFT JOIN Libros L ON P.LibroID = L.LibroID;

--RIGHT JOIN
SELECT 
    L.Titulo AS TituloLibro, 
    U.Nombre AS NombreUsuario, 
    P.FechaSalida AS FechaPrestamo
FROM Prestamos P
RIGHT JOIN Libros L ON P.LibroID = L.LibroID
LEFT JOIN Usuarios U ON P.UsuarioID = U.UsuarioID;

--FULL JOIN
SELECT 
    L.LibroID AS IdLibro, 
    L.Titulo AS TituloLibro, 
    P.PrestamoID AS IdPrestamo, 
    P.FechaSalida AS FechaPrestamo
FROM Libros L
FULL JOIN Prestamos P ON L.LibroID = P.LibroID;

--CROSS JOIN
SELECT 
    U.Nombre AS NombreUsuario, 
    L.Titulo AS TituloLibro
FROM Usuarios U
CROSS JOIN Libros L;

--UNION 
SELECT 
    Nombre AS NombrePersona, 
    'Es Usuario' AS TipoDato
FROM Usuarios 
UNION
SELECT 
    Titulo AS NombrePersona, 
    'Es Libro' AS TipoDato
FROM Libros;

